# Copy these into Vercel → Project → Settings → Environment Variables.
# (For local testing, copy this file to .env.local and fill it in.)

# Supabase — same project URL + SECRET (service_role) key your laptop uses.
# This stays server-side only; it is never shipped to the browser.
SUPABASE_URL=https://kcayyihkvjulcznpqswo.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Password to open the dashboard. Pick a strong one — anyone with it sees your data.
DASHBOARD_PASSWORD=change-this-to-something-strong
